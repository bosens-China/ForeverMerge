  <div class="absolute top-0 left-0 w-full h-full pointer-events-none flex items-center justify-center opacity-5">
    <span class="text-[20rem] font-serif text-primary leading-none">囍</span>
  </div>

  <div class="gsap-fade-up relative z-10 w-full max-w-sm bg-white/80 backdrop-blur-sm border border-accent/20 rounded-2xl p-8 shadow-sm text-center">
