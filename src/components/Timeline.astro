---
import { Heart } from '@lucide/astro';
import config from '../data/config.json';

const timelineEvents = config.timeline;
---

<section class="h-full w-full bg-bg-base relative flex flex-col justify-center">
  <div class="text-center mb-14 gsap-fade-up">
    <h2 class="text-3xl font-serif text-primary mb-2 tracking-widest">婚礼流程</h2>
    <p class="text-accent font-serif text-sm tracking-[0.2em] uppercase">Wedding Schedule</p>
  </div>

  <div class="max-w-xs mx-auto relative px-4">
    <!-- 垂直中轴线 -->
    <div class="absolute left-[39px] top-4 bottom-4 w-[2px] bg-accent/30"></div>

    <div class="space-y-10 timeline-container">
      {timelineEvents.map((event, index) => (
        <div class="relative flex items-start gap-6 timeline-item opacity-0 translate-y-8">
          <!-- 时间点圆圈 -->
          <div class="relative z-10 w-12 h-12 rounded-full bg-white border-2 border-primary flex items-center justify-center shrink-0 shadow-md">
            <span class="text-primary text-xs font-bold font-serif">{event.time}</span>
          </div>
          
          <!-- 内容卡片 -->
          <div class="flex-1 bg-white rounded-xl p-4 shadow-sm border border-accent/10 relative mt-1">
            <!-- 左侧小三角箭头 -->
            <div class="absolute top-4 -left-2 w-4 h-4 bg-white border-l border-b border-accent/10 transform rotate-45"></div>
            
            <h3 class="text-lg font-serif text-primary mb-1">{event.title}</h3>
            <p class="text-text-main/70 text-sm">{event.desc}</p>
            
            {index === 2 && (
              <div class="absolute top-4 right-4 text-accent/40 animate-pulse">
                <Heart size={20} fill="currentColor" />
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>