---
import config from '../data/config.json';

const video = config.video;
---

<section class="h-full w-full bg-bg-base relative flex flex-col justify-center">
  <div class="text-center mb-10 gsap-fade-up">
    <h2 class="text-3xl font-serif text-primary mb-2 tracking-widest">爱情影像</h2>
    <p class="text-accent font-serif text-sm tracking-[0.2em] uppercase">Our Story</p>
  </div>

  <div class="max-w-sm mx-auto px-6 gsap-fade-up">
    <div class="rounded-2xl overflow-hidden shadow-lg border border-accent/20 bg-white p-2">
      <!-- 视频容器：默认读取 public/video/main.mp4 -->
      <video 
        id="wedding-video"
        class="w-full rounded-xl object-cover aspect-[9/16] bg-gray-100"
        controls 
        playsinline
        webkit-playsinline
        preload="metadata"
        poster={video.poster}
      >
        <source src={video.src} type={video.type} />
        <p class="text-center py-10 text-text-main/50 text-sm">
          暂无视频或您的浏览器不支持视频播放。<br/>
          (请在配置中填写可访问的视频地址)
        </p>
      </video>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('wedding-video') as HTMLVideoElement;
    
    if (video) {
      video.addEventListener('play', () => {
        // 视频播放时暂停背景音乐
        window.dispatchEvent(new Event('pauseBgm'));
      });

      video.addEventListener('pause', () => {
        // 视频暂停时恢复背景音乐
        window.dispatchEvent(new Event('resumeBgm'));
      });

      video.addEventListener('ended', () => {
        // 视频结束时恢复背景音乐
        window.dispatchEvent(new Event('resumeBgm'));
      });
    }
  });
</script>
