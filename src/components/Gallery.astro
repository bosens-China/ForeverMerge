---
import config from '../data/config.json';

// 从配置文件读取图片列表
const images = config.gallery || [];

---

<section class="h-full w-full bg-white relative flex flex-col justify-center">
  <div class="text-center mb-10 gsap-fade-up">
    <h2 class="text-3xl font-serif text-primary mb-2 tracking-widest">幸福瞬间</h2>
    <p class="text-accent font-serif text-sm tracking-[0.2em] uppercase">Sweet Memories</p>
  </div>

  <!-- Swiper 容器 -->
  <div class="swiper mySwiper w-full px-4 pb-12 gsap-fade-up">
    <div class="swiper-wrapper">
      {(
        images.map((imgSrc, index) => (
          <div class="swiper-slide w-4/5 rounded-xl overflow-hidden shadow-lg border-4 border-white">
            <div class="aspect-[3/4] bg-gray-100 relative">
              <img src={imgSrc} alt={`婚纱照 ${index + 1}`} class="w-full h-full object-cover" />
            </div>
          </div>
        ))
      )}
    </div>
    <!-- 分页器 -->
    <div class="swiper-pagination mt-4"></div>
  </div>
</section>

<style>
  /* 覆盖 Swiper 的主题色为我们的主色调 */
  :root {
    --swiper-theme-color: var(--color-primary);
  }
  .swiper-slide {
    transition: transform 0.3s ease;
  }
  .swiper-slide-active {
    transform: scale(1.05);
  }
</style>

<script>
  import Swiper from 'swiper';
  import { EffectCards, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-cards';
  import 'swiper/css/pagination';

  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.mySwiper', {
      modules: [EffectCards, Pagination, Autoplay],
      effect: 'cards',
      grabCursor: true,
      centeredSlides: true,
      slidesPerView: 'auto',
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      pagination: {
        el: '.swiper-pagination',
        dynamicBullets: true,
      },
    });
  });
</script>