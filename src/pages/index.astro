---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import Invitation from '../components/Invitation.astro';
import Gallery from '../components/Gallery.astro';
import Timeline from '../components/Timeline.astro';
import VideoSection from '../components/VideoSection.astro';
import Location from '../components/Location.astro';

// 欢迎来到 Astro！这是您的首页。
---

<Layout title="我们结婚啦 - 婚礼请帖">
	<!-- 全局背景音乐播放器 -->
	<MusicPlayer />

	<main class="w-full h-[100dvh] overflow-y-auto overflow-x-hidden snap-y snap-mandatory bg-bg-base scroll-smooth">
		<!-- 1. 封面区 (Hero Section) -->
		<div class="snap-start snap-always h-[100dvh] w-full relative"><Hero /></div>

		<!-- 2. 诚挚邀请 (Invitation Letter) -->
		<div class="snap-start snap-always h-[100dvh] w-full relative"><Invitation /></div>

		<!-- 3. 照片画廊 (Photo Gallery) -->
		<div class="snap-start snap-always h-[100dvh] w-full relative"><Gallery /></div>

		<!-- 3.5 视频模块 (Video Section) -->
		<div class="snap-start snap-always h-[100dvh] w-full relative"><VideoSection /></div>

		<!-- 4. 婚礼流程 (Event Timeline) -->
		<div class="snap-start snap-always h-[100dvh] w-full relative"><Timeline /></div>

		<!-- 5. 导航与场地 (Location & Map) -->
		<div class="snap-start snap-always h-[100dvh] w-full relative"><Location /></div>
	</main>
</Layout>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	// 注册 ScrollTrigger 插件
	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("DOMContentLoaded", () => {
		// 为所有带有 gsap-fade-up 类的元素添加滚动渐显动画
		const fadeElements = document.querySelectorAll('.gsap-fade-up');
		
		fadeElements.forEach((el) => {
			gsap.fromTo(el, 
				{ 
					y: 30, 
					opacity: 0 
				},
				{
					y: 0,
					opacity: 1,
					duration: 0.8,
					ease: "power2.out",
					scrollTrigger: {
						trigger: el,
						scroller: "main", // 因为我们用了 main 作为滚动容器
						start: "top 80%",
						toggleActions: "play none none reverse"
					}
				}
			);
		});
	});
</script>